
<div class="d-flex flex-column flex-column-fluid">

  <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div id="kt_app_toolbar_container" class="app-container container-xxl d-flex flex-stack">

      <%# Left: Title + breadcrumb %>
      <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
        <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">
          Dashboard
        </h1>
        <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
          <li class="breadcrumb-item text-muted">
            <a href="/admin" class="text-muted text-hover-primary">Home</a>
          </li>
          <li class="breadcrumb-item"><span class="bullet bg-gray-400 w-5px h-2px"></span></li>
          <li class="breadcrumb-item text-muted">Dashboard</li>
        </ul>
      </div>

      <%# Right: Quick action buttons + timestamp %>
      <div class="d-flex align-items-center gap-3">
        <span class="text-muted fs-8 me-2">
          Updated: <strong class="text-dark" id="dash-time"></strong>
        </span>
        <a href="/admin/orders" class="btn btn-sm btn-light-primary fw-semibold">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="me-1" style="vertical-align:-2px">
            <path opacity=".3" d="M18 21.6C16.3 21.6 15 20.3 15 18.6V2.5c0-.3-.4-.5-.7-.3L13 3.6 11.7 2.3c-.4-.4-1-.4-1.4 0L9 3.6 7.7 2.3c-.4-.4-1-.4-1.4 0L5 3.6 3.7 2.3C3.5 2.1 3 2.2 3 3.5V18.6C3 20.3 4.3 21.6 6 21.6H18z" fill="currentColor"/>
            <path d="M7 7h8M7 10h8M7 13h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          All Orders
        </a>
        <a href="/admin/products/add" class="btn btn-sm btn-primary fw-semibold">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" class="me-1" style="vertical-align:-2px">
            <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
          Add Product
        </a>
      </div>

    </div>
  </div>

  <%# ── Main Content ─────────────────────────────────────── %>
  <div id="kt_app_content" class="app-content flex-column-fluid">
    <div id="kt_app_content_container" class="app-container container-xxl">

      <%# ── KPI Cards ──────────────────────────────────────── %>
      <div class="row g-5 mb-6">

        <%# Revenue %>
        <div class="col-sm-6 col-xl-3">
          <div class="card dash-kpi h-100">
            <div class="card-body p-6">
              <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="dash-icon" style="background:rgba(233,69,96,.1);color:#e94560">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path opacity=".3" d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z" fill="currentColor"/><path d="M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM2 11h4M18 11h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </div>
                <span class="badge badge-light-success fs-8">Revenue</span>
              </div>
              <div class="dash-value">
                <%
                  const rev = stats.totalRevenue || 0;
                  let revDisplay;
                  if (rev >= 100000) revDisplay = '₹' + (rev/100000).toFixed(1) + 'L';
                  else if (rev >= 1000) revDisplay = '₹' + (rev/1000).toFixed(1) + 'K';
                  else revDisplay = '₹' + rev;
                %>
                <%= revDisplay %>
              </div>
              <div class="dash-label">Total Revenue</div>
              <div class="dash-footer">
                <span class="text-muted fs-8">From successful payments</span>
              </div>
            </div>
          </div>
        </div>

        <%# Total Orders %>
        <div class="col-sm-6 col-xl-3">
          <div class="card dash-kpi h-100">
            <div class="card-body p-6">
              <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="dash-icon" style="background:rgba(26,158,110,.1);color:#1a9e6e">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path opacity=".3" d="M18 21.6C16.3 21.6 15 20.3 15 18.6V2.5c0-.3-.4-.5-.7-.3L13 3.6 11.7 2.3c-.4-.4-1-.4-1.4 0L9 3.6 7.7 2.3c-.4-.4-1-.4-1.4 0L5 3.6 3.7 2.3C3.5 2.1 3 2.2 3 3.5V18.6C3 20.3 4.3 21.6 6 21.6H18z" fill="currentColor"/><path d="M7 7h8M7 10h8M7 13h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </div>
                <span class="badge badge-light-info fs-8">All time</span>
              </div>
              <div class="dash-value"><%= (stats.totalOrders || 0).toLocaleString('en-IN') %></div>
              <div class="dash-label">Total Orders</div>
              <div class="dash-footer">
                <a href="/admin/orders" class="dash-link">View all orders →</a>
              </div>
            </div>
          </div>
        </div>

        <%# Total Users %>
        <div class="col-sm-6 col-xl-3">
          <div class="card dash-kpi h-100">
            <div class="card-body p-6">
              <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="dash-icon" style="background:rgba(15,52,96,.1);color:#0f3460">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path opacity=".3" d="M22 12c0 5.5-4.5 10-10 10S2 17.5 2 12 6.5 2 12 2s10 4.5 10 10zM12 7c-1.7 0-3 1.3-3 3s1.3 3 3 3 3-1.3 3-3-1.3-3-3-3z" fill="currentColor"/><path d="M12 22c2.6 0 5-1 6.7-2.6C17.9 16.9 15.2 15 12 15c-3.2 0-5.9 1.9-6.7 4.4C7 21 9.4 22 12 22z" fill="currentColor"/></svg>
                </div>
                <span class="badge badge-light-primary fs-8"><%= stats.newUsersThisMonth %> new</span>
              </div>
              <div class="dash-value"><%= (stats.totalUsers || 0).toLocaleString('en-IN') %></div>
              <div class="dash-label">Total Customers</div>
              <div class="dash-footer">
                <a href="/admin/users" class="dash-link">View all users →</a>
              </div>
            </div>
          </div>
        </div>

        <%# Avg Order Value %>
        <div class="col-sm-6 col-xl-3">
          <div class="card dash-kpi h-100">
            <div class="card-body p-6">
              <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="dash-icon" style="background:rgba(243,156,18,.1);color:#d4900a">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path opacity=".3" d="M12 2 2 7l10 5 10-5-10-5z" fill="currentColor"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
                <span class="badge badge-light-warning fs-8"><%= stats.totalProducts %> products</span>
              </div>
              <div class="dash-value">
                <%
                  const aov = stats.avgOrderValue || 0;
                  let aovDisplay;
                  if (aov >= 1000) aovDisplay = '₹' + (aov/1000).toFixed(1) + 'K';
                  else aovDisplay = '₹' + aov;
                %>
                <%= aovDisplay %>
              </div>
              <div class="dash-label">Avg Order Value</div>
              <div class="dash-footer">
                <span class="text-muted fs-8"><%= stats.cancelledOrders || 0 %> cancelled orders</span>
              </div>
            </div>
          </div>
        </div>

      </div>
      <%# end KPI row %>

      <%# ── Charts Row ──────────────────────────────────────── %>
      <div class="row g-5 mb-6">

        <%# Revenue Line Chart — 7 days %>
        <div class="col-xl-8">
          <div class="card card-flush h-100">
            <div class="card-header pt-5 border-0">
              <h3 class="card-title fw-bold text-dark">Revenue — Last 7 Days</h3>
              <div class="card-toolbar">
                <span class="text-muted fs-8 fw-semibold">Daily revenue from payments</span>
              </div>
            </div>
            <div class="card-body pt-3">
              <div style="position:relative;height:260px;width:100%">
                <canvas id="revenueChart"></canvas>
              </div>
            </div>
          </div>
        </div>

        <%# Order Status Doughnut %>
        <div class="col-xl-4">
          <div class="card card-flush h-100">
            <div class="card-header pt-5 border-0">
              <h3 class="card-title fw-bold text-dark">Order Status</h3>
            </div>
            <div class="card-body pt-0">
              <div style="position:relative;height:180px;width:100%;max-width:190px;margin:0 auto">
                <canvas id="statusChart"></canvas>
              </div>
              <div class="mt-5" id="status-legend">
                <% const statusColors = {PENDING:'#e94560',CONFIRMED:'#0f3460',SHIPPED:'#f39c12',DELIVERED:'#1a9e6e',CANCELLED:'#e74c3c'}; %>
                <% Object.entries(stats.orderStatus || {}).forEach(([status, count]) => { %>
                  <div class="d-flex align-items-center justify-content-between mb-2">
                    <span class="d-flex align-items-center gap-2 text-muted fs-8">
                      <span style="width:9px;height:9px;border-radius:2px;background:<%= statusColors[status] || '#ccc' %>;display:inline-block;"></span>
                      <%= status %>
                    </span>
                    <span class="fw-bold text-dark fs-8"><%= (count || 0).toLocaleString('en-IN') %></span>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        </div>

      </div>
      <%# end charts row %>

      <%# ── Bottom Row ──────────────────────────────────────── %>
      <div class="row g-5">

        <%# Recent Orders Table %>
        <div class="col-xl-7">
          <div class="card card-flush h-100">
            <div class="card-header pt-5 border-0">
              <h3 class="card-title fw-bold text-dark">Recent Orders</h3>
              <div class="card-toolbar">
                <a href="/admin/orders" class="btn btn-sm btn-light-primary">View All</a>
              </div>
            </div>
            <div class="card-body py-3">
              <div class="table-responsive">
                <table class="table table-row-dashed align-middle gs-0 gy-3">
                  <thead>
                    <tr class="fw-bold text-muted fs-8 text-uppercase">
                      <th class="ps-2">Customer</th>
                      <th>Order ID</th>
                      <th>Status</th>
                      <th class="text-end pe-2">Amount</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (stats.recentOrdersFormatted && stats.recentOrdersFormatted.length > 0) { %>
                      <% stats.recentOrdersFormatted.forEach(order => { %>
                        <%
                          const sMap = {
                            PENDING:   {bg:'rgba(233,69,96,.1)',   color:'#e94560'},
                            CONFIRMED: {bg:'rgba(15,52,96,.1)',    color:'#0f3460'},
                            SHIPPED:   {bg:'rgba(243,156,18,.1)',  color:'#d4900a'},
                            DELIVERED: {bg:'rgba(26,158,110,.1)',  color:'#1a9e6e'},
                            CANCELLED: {bg:'rgba(231,76,60,.1)',   color:'#e74c3c'},
                          };
                          const st = sMap[order.status] || sMap['PENDING'];
                          const initials = (order.userName || 'U').split(' ').map(w => w[0]).join('').toUpperCase().slice(0,2);
                          const dateStr = new Date(order.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short'});
                        %>
                        <tr>
                          <td class="ps-2">
                            <div class="d-flex align-items-center">
                              <div class="symbol symbol-35px me-3">
                                <div class="symbol-label bg-light-primary text-primary fw-bold fs-7"><%= initials %></div>
                              </div>
                              <div>
                                <span class="fw-semibold text-dark d-block fs-8"><%= order.userName %></span>
                                <span class="text-muted fs-9"><%= dateStr %></span>
                              </div>
                            </div>
                          </td>
                          <td>
                            <a href="/admin/orders/<%= order.id %>" class="text-dark fw-semibold text-hover-primary fs-8">#<%= order.id %></a>
                          </td>
                          <td>
                            <span class="badge rounded-pill fw-semibold fs-9" style="background:<%= st.bg %>;color:<%= st.color %>;">
                              <%= order.status %>
                            </span>
                          </td>
                          <td class="text-end pe-2 fw-bold text-dark fs-8">
                            ₹<%= (order.total || 0).toLocaleString('en-IN') %>
                          </td>
                        </tr>
                      <% }) %>
                    <% } else { %>
                      <tr><td colspan="4" class="text-center text-muted py-8">No orders yet</td></tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <%# Top Categories %>
        <div class="col-xl-5">
          <div class="card card-flush h-100">
            <div class="card-header pt-5 border-0">
              <h3 class="card-title fw-bold text-dark">Top Categories</h3>
              <div class="card-toolbar">
                <span class="text-muted fs-8">By items sold</span>
              </div>
            </div>
            <div class="card-body pt-3">
              <%
                const catColors = ['#e94560','#0f3460','#1a9e6e','#f39c12','#9b59b6'];
                const maxSold = stats.topCategories && stats.topCategories.length > 0
                  ? Math.max(...stats.topCategories.map(c => c.sold), 1)
                  : 1;
              %>
              <% if (stats.topCategories && stats.topCategories.length > 0) { %>
                <% stats.topCategories.forEach((cat, i) => { %>
                  <%
                    const pct = Math.round((cat.sold / maxSold) * 100);
                    const color = catColors[i % catColors.length];
                  %>
                  <div class="mb-5">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                      <span class="fw-semibold text-dark fs-8"><%= cat.name %></span>
                      <span class="text-muted fs-9"><%= cat.sold %> sold</span>
                    </div>
                    <div style="height:7px;background:#f0f2f5;border-radius:50px;overflow:hidden">
                      <div style="width:<%= pct %>%;height:100%;background:<%= color %>;border-radius:50px"></div>
                    </div>
                  </div>
                <% }) %>
              <% } else { %>
                <div class="text-center text-muted py-8 fs-8">No sales data yet</div>
              <% } %>

              <%# Quick store vitals below categories %>
              <div class="separator border-gray-200 my-5"></div>
              <div class="d-flex flex-column gap-3">
                <div class="d-flex justify-content-between">
                  <span class="text-muted fs-8 fw-semibold">Total Categories</span>
                  <span class="fw-bold text-dark fs-8"><%= stats.totalCategories %></span>
                </div>
                <div class="d-flex justify-content-between">
                  <span class="text-muted fs-8 fw-semibold">Sub Categories</span>
                  <span class="fw-bold text-dark fs-8"><%= stats.totalSubCategories %></span>
                </div>
                <div class="d-flex justify-content-between">
                  <span class="text-muted fs-8 fw-semibold">Total Products</span>
                  <span class="fw-bold text-dark fs-8"><%= stats.totalProducts %></span>
                </div>
                <div class="d-flex justify-content-between">
                  <span class="text-muted fs-8 fw-semibold">New Users (month)</span>
                  <span class="fw-bold text-dark fs-8" style="color:#1a9e6e">+<%= stats.newUsersThisMonth %></span>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
      <%# end bottom row %>

    </div>
  </div>
</div>

<%# ── Styles ─────────────────────────────────────────────── %>
<style>
.dash-kpi {
  border-radius: 16px !important;
  border: 1px solid #eef0f4 !important;
  transition: transform .2s, box-shadow .2s !important;
}
.dash-kpi:hover {
  transform: translateY(-3px) !important;
  box-shadow: 0 12px 32px rgba(0,0,0,.10) !important;
}
.dash-icon {
  width: 48px; height: 48px; border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.dash-value {
  font-size: 1.9rem; font-weight: 800; color: #1a1a2e;
  line-height: 1.1; letter-spacing: -0.8px;
}
.dash-label {
  font-size: 0.75rem; font-weight: 700; color: #8a95a8;
  margin-top: 4px; text-transform: uppercase; letter-spacing: 0.6px;
}
.dash-footer {
  border-top: 1px solid #f0f2f5;
  padding-top: .65rem; margin-top: .75rem;
}
.dash-link {
  font-size: .82rem; font-weight: 600;
  color: #e94560; text-decoration: none;
}
.dash-link:hover { color: #c73652; }
</style>

<%# ── Scripts ────────────────────────────────────────────── %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
// Timestamp
const timeEl = document.getElementById('dash-time');
if (timeEl) {
  timeEl.textContent = new Date().toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
}

// ── Revenue chart (data injected server-side) ─────────────
const revenueLabels = <%- JSON.stringify(stats.revenueChart ? stats.revenueChart.labels : []) %>;
const revenueData   = <%- JSON.stringify(stats.revenueChart ? stats.revenueChart.data : []) %>;

(function buildRevenueChart() {
  const ctx  = document.getElementById('revenueChart').getContext('2d');
  const grad = ctx.createLinearGradient(0, 0, 0, 260);
  grad.addColorStop(0, 'rgba(233,69,96,.18)');
  grad.addColorStop(1, 'rgba(233,69,96,0)');

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: revenueLabels,
      datasets: [{
        label: 'Revenue (₹)',
        data: revenueData,
        borderColor: '#e94560',
        backgroundColor: grad,
        borderWidth: 2.5,
        tension: 0.4,
        pointRadius: 4,
        pointBackgroundColor: '#e94560',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        fill: true,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: v => '₹' + Number(v.raw).toLocaleString('en-IN')
          }
        }
      },
      scales: {
        x: {
          grid: { display: false },
          ticks: { font: { size: 12 }, color: '#a0aab8' }
        },
        y: {
          grid: { color: '#f4f5f7' },
          ticks: {
            font: { size: 12 },
            color: '#a0aab8',
            callback: v => v >= 1000 ? '₹' + (v/1000).toFixed(0) + 'K' : '₹' + v
          }
        }
      }
    }
  });
})();

// ── Order status doughnut (data injected server-side) ─────
const statusData = <%- JSON.stringify(stats.orderStatus || {}) %>;

(function buildStatusChart() {
  const order  = ['PENDING','CONFIRMED','SHIPPED','DELIVERED','CANCELLED'];
  const colors = ['#e94560','#0f3460','#f39c12','#1a9e6e','#e74c3c'];
  const data   = order.map(s => statusData[s] || 0);

  new Chart(document.getElementById('statusChart').getContext('2d'), {
    type: 'doughnut',
    data: {
      labels: order,
      datasets: [{
        data,
        backgroundColor: colors,
        borderWidth: 0,
        hoverOffset: 6,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      cutout: '70%'
    }
  });
})();
</script>