<div class="d-flex flex-column flex-column-fluid">
  <div id="kt_app_toolbar" class="app-toolbar py-3 py-lg-6">
    <div class="app-container container-xxl d-flex flex-stack">
      <div class="page-title d-flex flex-column justify-content-center flex-wrap me-3">
        <h1 class="page-heading d-flex text-dark fw-bold fs-3 flex-column justify-content-center my-0">
          <%= editMode ? 'Edit Product' : 'Add Product' %>
        </h1>
        <ul class="breadcrumb breadcrumb-separatorless fw-semibold fs-7 my-0 pt-1">
          <li class="breadcrumb-item text-muted">
            <a href="/admin" class="text-muted text-hover-primary">Home</a>
          </li>
          <li class="breadcrumb-item"><span class="bullet bg-gray-400 w-5px h-2px"></span></li>
          <li class="breadcrumb-item text-muted">
            <a href="/admin/products" class="text-muted text-hover-primary">Products</a>
          </li>
          <li class="breadcrumb-item"><span class="bullet bg-gray-400 w-5px h-2px"></span></li>
          <li class="breadcrumb-item text-muted"><%= editMode ? 'Edit' : 'Add' %></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="app-content flex-column-fluid">
    <div class="app-container container-xxl">
      <form id="product-form" enctype="multipart/form-data">
        <% if (editMode) { %>
          <input type="hidden" id="product-id" value="<%= product.id %>" />
        <% } %>

        <div class="row g-5">

          <!-- Left Column -->
          <div class="col-lg-8">

            <!-- General Info -->
            <div class="card mb-5">
              <div class="card-header">
                <h3 class="card-title fw-bold">General Information</h3>
              </div>
              <div class="card-body">

                <div class="mb-5">
                  <label class="form-label required fw-semibold">Product Name</label>
                  <input type="text" id="product-name" class="form-control form-control-solid"
                    placeholder="Enter product name"
                    value="<%= editMode ? product.name : '' %>" />
                </div>

                <div class="mb-5">
                  <label class="form-label fw-semibold">Description</label>
                  <textarea id="product-description" class="form-control form-control-solid"
                    rows="5" placeholder="Enter product description"><%= editMode ? product.description || '' : '' %></textarea>
                </div>

                <div class="row">
                  <div class="col-md-4 mb-5">
                    <label class="form-label required fw-semibold">Price (₹)</label>
                    <input type="number" id="product-price" class="form-control form-control-solid"
                      placeholder="0.00" min="0" step="0.01"
                      value="<%= editMode ? product.price : '' %>" />
                  </div>
                  <div class="col-md-4 mb-5">
                    <label class="form-label fw-semibold">Discount (%)</label>
                    <input type="number" id="product-discount" class="form-control form-control-solid"
                      placeholder="0" min="0" max="100" step="0.01"
                      value="<%= editMode ? product.discount : '' %>" />
                  </div>
                  <div class="col-md-4 mb-5">
                    <label class="form-label required fw-semibold">Stock</label>
                    <input type="number" id="product-stock" class="form-control form-control-solid"
                      placeholder="0" min="0" step="1"
                      value="<%= editMode ? product.stock : '' %>" />
                  </div>
                </div>

              </div>
            </div>

            <!-- Images -->
            <div class="card mb-5">
              <div class="card-header">
                <h3 class="card-title fw-bold">Product Images</h3>
              </div>
              <div class="card-body">

                <div class="mb-6">
                  <label class="form-label fw-semibold">Main Image</label>
                  <% if (editMode && product.image) { %>
                    <div class="mb-3">
                      <img id="current-main-image" src="<%= product.image %>"
                        alt="Main Image" class="rounded"
                        style="width:120px;height:120px;object-fit:cover;" />
                    </div>
                  <% } %>
                  <input type="file" id="product-image" class="form-control form-control-solid"
                    accept="image/jpeg,image/jpg,image/png,image/gif,image/webp" />
                  <small class="text-muted">Max 5MB. Allowed: jpeg, jpg, png, gif, webp</small>
                </div>

                <div class="mb-4">
                  <label class="form-label fw-semibold">Gallery Images <span class="text-muted">(max 5)</span></label>
                  <% if (editMode && product.images && product.images.length > 0) { %>
                    <div class="d-flex flex-wrap gap-3 mb-3" id="current-gallery">
                      <% product.images.forEach(function(img) { %>
                        <img src="<%= img %>" alt="Gallery" class="rounded"
                          style="width:80px;height:80px;object-fit:cover;" />
                      <% }) %>
                    </div>
                  <% } %>
                  <input type="file" id="product-images" class="form-control form-control-solid"
                    accept="image/jpeg,image/jpg,image/png,image/gif,image/webp" multiple />
                  <small class="text-muted">Select up to 5 images. Uploading new images will replace existing ones.</small>
                </div>

              </div>
            </div>

          </div>

          <!-- Right Column -->
          <div class="col-lg-4">

            <!-- Status & Settings -->
            <div class="card mb-5">
              <div class="card-header">
                <h3 class="card-title fw-bold">Settings</h3>
              </div>
              <div class="card-body">

                <div class="mb-5">
                  <label class="form-label required fw-semibold">Sub Category</label>
                  <select id="product-subCategoryId" class="form-select form-select-solid">
                    <option value="">Select Sub Category</option>
                    <% subCategories.forEach(function(sub) { %>
                      <option value="<%= sub.id %>"
                        <%= editMode && product.subCategoryId === sub.id ? 'selected' : '' %>>
                        <%= sub.name %> (<%= sub.category.name %>)
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="mb-5">
                  <label class="form-label fw-semibold">Status</label>
                  <select id="product-status" class="form-select form-select-solid">
                    <option value="ACTIVE" <%= editMode && product.status === 'ACTIVE' ? 'selected' : '' %>>Active</option>
                    <option value="INACTIVE" <%= editMode && product.status === 'INACTIVE' ? 'selected' : '' %>>Inactive</option>
                  </select>
                </div>

                <div class="mb-5">
                  <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="product-isFeatured"
                      <%= editMode && product.isFeatured ? 'checked' : '' %> />
                    <label class="form-check-label fw-semibold" for="product-isFeatured">
                      Featured Product
                    </label>
                  </div>
                  <small class="text-muted">Featured products are highlighted on the storefront.</small>
                </div>

              </div>
            </div>

            <!-- Actions -->
            <div class="card">
              <div class="card-body">
                <div class="d-flex flex-column gap-3">
                  <button type="button" id="save-product" class="btn btn-primary w-100">
                    <span class="indicator-label"><%= editMode ? 'Update Product' : 'Create Product' %></span>
                    <span class="indicator-progress">
                      Please wait...
                      <span class="spinner-border spinner-border-sm align-middle ms-2"></span>
                    </span>
                  </button>
                  <a href="/admin/products" class="btn btn-light w-100">Cancel</a>
                </div>
              </div>
            </div>

          </div>
        </div>

      </form>
    </div>
  </div>
</div>